{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "// exclude note": "The generator also emits a full-featured rpc-client.ts (batch/abort/instrumentation) we don't use — src/lib/rpc-client.ts is used instead. Exclude it from type-checking.",
  "exclude": ["src/generated/rpc-client.ts"]
}
